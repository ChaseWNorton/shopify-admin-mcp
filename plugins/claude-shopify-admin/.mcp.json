{
  "mcpServers": {
    "shopify": {
      "command": "npx",
      "args": [
        "-y",
        "shopify-admin-mcp"
      ],
      "env": {
        "SHOPIFY_STORE": "${user_config.shopify_store}",
        "SHOPIFY_API_VERSION": "${user_config.shopify_api_version}",
        "SHOPIFY_CLIENT_ID": "${user_config.shopify_client_id}",
        "SHOPIFY_CLIENT_SECRET": "${user_config.shopify_client_secret}"
      }
    }
  }
}
